@startuml reconciliation_event_diagram
title Схема события сверки

entity "Событие сверки" as ReconciliationEvent {
  * event_id : UUID
  --
  event_type : string
  event_version : integer
  correlation_id : UUID
  occurred_at : datetime
  source : string
  conflict_id : UUID
  sku_id : UUID
  store_id : UUID
  expected_qty : integer
  actual_qty : integer
  difference_qty : integer
  reconciliation_status : string
  resolution_method : string
}

@enduml