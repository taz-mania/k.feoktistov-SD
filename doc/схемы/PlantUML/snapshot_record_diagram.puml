@startuml snapshot_record_diagram
title Схема хранения снимков состояния

entity "Снимок состояния" as Snapshot {
  * snapshot_id : UUID
  --
  snapshot_time : datetime
  last_event_id : UUID
  schema_version : integer
  records_count : integer
  status : string
}

entity "Состояние остатка" as SnapshotRecord {
  * snapshot_record_id : UUID
  --
  snapshot_id : UUID
  sku_id : UUID
  store_id : UUID
  available_qty : integer
  reserved_qty : integer
  version : integer
}

Snapshot ||--o{ SnapshotRecord : содержит

@enduml