@startuml test_flow_diagram
title Схема испытаний Сервиса

skinparam shadowing false
skinparam defaultFontName Arial
skinparam activity {
BackgroundColor #F8F8F8
BorderColor #444444
FontColor #222222
}

start

:Изменение исходного кода\nили конфигурации;
:Запуск CI/CD-конвейера;

partition "Автоматизированные проверки" {
:Сборка компонентов;
:Модульные тесты;
:Интеграционные тесты;
:Проверка API и событийных контрактов;
}

if (Проверки успешны?) then (да)
:Развертывание в тестовое окружение;
else (нет)
:Возврат изменений на доработку;
stop
endif

partition "Системные испытания" {
:Проверка пользовательских сценариев;
:Проверка операций проверки доступности товаров;
:Проверка операций резервирования;
:Проверка обработки событий через Event Bus;
:Проверка обновления модели чтения и кэша;
}

if (Системные испытания успешны?) then (да)
:Развертывание в предпромышленное окружение;
else (нет)
:Исправление дефектов;
stop
endif

partition "Нагрузочные и отказоустойчивые испытания" {
:Нагрузочное тестирование\nтиповых и пиковых сценариев;
:Проверка поведения при деградации компонентов;
:Проверка восстановления после сбоев;
:Проверка выполнения целевых показателей\nпроизводительности и надежности;
}

partition "Проверка эксплуатационной готовности" {
:Проверка метрик и журналов;
:Проверка срабатывания алертов;
:Проверка возможности анализа деградации\nпосле обновления;
}

if (Критерии приемки выполнены?) then (да)
:Решение о готовности релиза;
:Продвижение релиза в промышленное окружение;
else (нет)
:Доработка релиза\nили откат к предыдущей версии;
stop
endif

stop
@enduml
