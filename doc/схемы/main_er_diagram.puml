@startuml main_er_diagram
title Упрощенная ER-диаграмма основных сущностей Сервиса

entity "Магазин" as Store 

entity "Товар" as Product 

entity "Остаток" as Stock 

entity "Резерв" as Reservation 

entity "Операция резервирования" as ReservationOperation 

entity "Событие изменения остатка" as StockEvent 

entity "Конфликт сверки" as ReconciliationConflict 

entity "Snapshot модели чтения" as ReadModelSnapshot 

entity "Состояние остатка в snapshot" as SnapshotStock 

Store ||--o{ Stock : содержит
Product ||--o{ Stock : представлен в
Stock ||--o{ Reservation : связан с
Reservation ||--o{ ReservationOperation : содержит
Stock ||--o{ StockEvent : порождает
Product ||--o{ ReconciliationConflict : участвует в
Store ||--o{ ReconciliationConflict : участвует в
ReadModelSnapshot ||--o{ SnapshotStock : содержит
Stock ||--o{ SnapshotStock : фиксируется в

@enduml