@startuml full_er_diagram
title Полная ER-диаграмма основных сущностей Сервиса 
skinparam linetype ortho

entity "Магазин" as Store {
  * store_id : UUID
  --
  name : string
  region_id : UUID
  status : string
}

entity "Товар" as Product {
  * sku_id : UUID
  --
  name : string
  category_id : UUID
  status : string
}

entity "Остаток" as Stock {
  * stock_id : UUID
  --
  sku_id : UUID
  store_id : UUID
  available_qty : integer
  reserved_qty : integer
  version : integer
  updated_at : datetime
}

entity "Резерв" as Reservation {
  * reservation_id : UUID
  --
  stock_id : UUID
  sku_id : UUID
  store_id : UUID
  reserved_qty : integer
  status : string
  expires_at : datetime
  created_at : datetime
}

entity "Операция резервирования" as ReservationOperation {
  * operation_id : UUID
  --
  reservation_id : UUID
  operation_type : string
  operation_status : string
  idempotency_key : string
  created_at : datetime
}

entity "Событие изменения остатка" as StockEvent {
  * event_id : UUID
  --
  stock_id : UUID
  sku_id : UUID
  store_id : UUID
  event_type : string
  event_version : integer
  occurred_at : datetime
}

entity "Конфликт сверки" as ReconciliationConflict {
  * conflict_id : UUID
  --
  sku_id : UUID
  store_id : UUID
  expected_qty : integer
  actual_qty : integer
  conflict_status : string
  detected_at : datetime
}

entity "Snapshot модели чтения" as ReadModelSnapshot {
  * snapshot_id : UUID
  --
  snapshot_time : datetime
  version : integer
  status : string
}

entity "Состояние остатка в snapshot" as SnapshotStock {
  * snapshot_stock_id : UUID
  --
  snapshot_id : UUID
  stock_id : UUID
  sku_id : UUID
  store_id : UUID
  available_qty : integer
  reserved_qty : integer
  version : integer
}

Store "содержит" ||--o{ Stock 
Product ||--o{ Stock : представлен_в
Stock ||--o{ Reservation : связан_с
Reservation ||--o{ ReservationOperation : содержит
Stock ||--o{ StockEvent : порождает
Product ||--o{ ReconciliationConflict : участвует_в
Store ||--o{ ReconciliationConflict : участвует_в
ReadModelSnapshot ||--o{ SnapshotStock : содержит
Stock ||--o{ SnapshotStock : фиксируется_в

@enduml
