@startuml service_authentification
title Механизм аутентификации сервисов

actor "Внутренний сервис\nинициатор запроса" as ServiceA
participant "HashiCorp Vault" as Vault
participant "Доверенная инфраструктура\nсертификатов Сервиса" as CA
participant "Внутренний сервис\nполучатель запроса" as ServiceB

== Получение сервисного сертификата ==

ServiceA -> Vault : запрос сервисного сертификата\nи закрытого ключа
Vault -> Vault : проверка сервисной учетной записи\nи политики доступа

alt Доступ разрешен
  Vault -> CA : запрос выпуска\nсервисного сертификата
  CA --> Vault : сервисный сертификат
  Vault --> ServiceA : сертификат mTLS,\nзакрытый ключ,\nсрок действия
else Доступ запрещен
  Vault --> ServiceA : отказ в выдаче сертификата
end

ServiceB -> Vault : запрос собственного\nсервисного сертификата
Vault -> Vault : проверка сервисной учетной записи\nи политики доступа

alt Доступ разрешен
  Vault -> CA : запрос выпуска\nсервисного сертификата
  CA --> Vault : сервисный сертификат
  Vault --> ServiceB : сертификат mTLS,\nзакрытый ключ,\nсрок действия
else Доступ запрещен
  Vault --> ServiceB : отказ в выдаче сертификата
end

== Установление защищенного соединения ==

ServiceA -> ServiceB : gRPC over HTTP/2\nинициация mTLS-соединения
ServiceB -> ServiceA : предъявление\nсервисного сертификата
ServiceA -> ServiceB : предъявление\nсервисного сертификата

ServiceA -> ServiceA : проверка сертификата\nсервиса-получателя
ServiceB -> ServiceB : проверка сертификата\nсервиса-инициатора

alt Сертификаты действительны
  ServiceB -> ServiceB : определение сервисной роли\nвызывающего сервиса
  ServiceB -> ServiceB : проверка допустимости\nзапрошенной операции

  alt Операция разрешена
    ServiceA -> ServiceB : сервисный запрос\nс проверенной идентичностью
    ServiceB --> ServiceA : результат выполнения операции
  else Операция запрещена
    ServiceB --> ServiceA : отказ в выполнении операции
  end

else Сертификат недействителен
  ServiceB --> ServiceA : отказ в соединении
end

== Истечение срока действия сертификата ==

ServiceA -> Vault : запрос обновления\nсервисного сертификата
Vault -> Vault : проверка сервисной роли\nи срока действия сертификата
Vault --> ServiceA : новый сертификат mTLS

@enduml
